      "description": "Emits true/false on toggle.",
      "required": false,
      "multiple": false,
      "schema": {
        "type": {
          "name": "boolean"
        }
      }
    }
  ],
  "files": {
    "readme": "README.md",
    "entry": "dm_input_switch/main.py",
    "tests": [],
    "examples": []
  },
  "interaction": {
    "emit": ["widgets"],
    "on": true
  },
  "examples": [],
  "config_schema": {
    "default_value": {
      "default": "false",
