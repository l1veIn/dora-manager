{
  "id": "dm-display",
  "name": "dm-display",
  "version": "0.1.0",
  "installed_at": "1776692257",
  "source": {
    "build": "pip install -e .",
    "github": null
  },
  "description": "Relay display messages to dm-server for the current run UI. Supports inline content (text/json) via the data port and artifact files via the path port.",
  "executable": ".venv/bin/dm-display",
  "maintainers": [
    {
      "name": "Dora Manager"
    }
  ],
  "display": {
    "category": "Builtin/Interaction",
    "tags": [
      "builtin",
      "interaction",
      "display"
    ]
  },
  "capabilities": [
    "configurable",
    {
      "name": "display",
      "bindings": [
        {
          "role": "source",
          "port": "data",
          "channel": "inline",
          "media": [
            "text",
            "json",
            "markdown"
          ],
          "lifecycle": [],
          "description": "Relays inline display content into the DM interaction plane."
        },
        {
          "role": "source",
          "port": "path",
          "channel": "artifact",
          "media": [
            "image",
            "audio",
            "video",
            "text",
            "json",
            "markdown"
          ],
          "lifecycle": [],
          "description": "Relays artifact-backed display content into the DM interaction plane."
        }
      ]
    }
  ],
  "runtime": {
    "language": "python",
    "python": ">=3.10",
    "platforms": []
  },
  "ports": [
    {
      "id": "path",
      "name": "path",
      "direction": "input",
      "description": "Path emitted by a storage-family node.",
      "required": false,
      "multiple": false,
      "schema": {
        "type": {
          "name": "utf8"
        }
      }
    },
    {
      "id": "data",
      "name": "data",
      "direction": "input",
      "description": "Lightweight displayable content sent directly to the UI without going through artifact storage.",
      "required": false,
      "multiple": false,
      "schema": {
        "type": {
          "name": "utf8"
        }
      }
    }
  ],
  "files": {
    "readme": "README.md",
    "entry": "dm_display/main.py",
    "tests": [],
    "examples": []
  },
  "examples": [],
  "config_schema": {
    "label": {
      "default": "",
      "description": "Display label shown in the UI.",
      "env": "LABEL"
    },
    "render": {
      "default": "auto",
      "description": "Render mode: auto, text, image, audio, video, json, markdown. For data input, auto resolves to text/json.",
      "env": "RENDER"
    }
  },
  "dynamic_ports": false,
  "path": ""
}