{
  "id": "dm-test-media-capture",
  "name": "dm-test-media-capture",
  "version": "0.1.0",
  "installed_at": "1772779524",
  "source": {
    "build": "pip install -e ."
  },
  "description": "Builtin DM test node for screenshot capture.",
  "executable": ".venv/bin/dm-test-media-capture",
  "maintainers": [
    {
      "name": "Dora Manager"
    }
  ],
  "display": {
    "category": "Builtin/Test",
    "tags": [
      "builtin",
      "test"
    ]
  },
  "capabilities": [
    "configurable",
    "media"
  ],
  "runtime": {
    "language": "python",
    "python": ">=3.10",
    "platforms": []
  },
  "ports": [
    {
      "id": "trigger",
      "name": "trigger",
      "direction": "input",
      "description": "Capture trigger signal",
      "required": true,
      "multiple": false,
      "schema": { "type": { "name": "null" }, "description": "Trigger event, payload is ignored" }
    },
    {
      "id": "image",
      "name": "image",
      "direction": "output",
      "description": "Captured screenshot",
      "required": true,
      "multiple": false,
      "schema": {
        "type": { "name": "int", "bitWidth": 8, "isSigned": false },
        "description": "PNG/JPEG encoded image bytes"
      }
    },
    {
      "id": "video",
      "name": "video",
      "direction": "output",
      "description": "Captured video clip",
      "required": true,
      "multiple": false,
      "schema": {
        "type": { "name": "int", "bitWidth": 8, "isSigned": false },
        "description": "Encoded video bytes"
      }
    },
    {
      "id": "meta",
      "name": "meta",
      "direction": "output",
      "description": "Capture metadata",
      "required": true,
      "multiple": false,
      "schema": { "type": { "name": "utf8" }, "description": "JSON-encoded capture metadata" }
    }
  ],
  "files": {
    "readme": "README.md",
    "entry": "dm_test_media_capture/main.py",
    "tests": [],
    "examples": []
  },
  "examples": [],
  "config_schema": {
    "mode": {
      "env": "MODE",
      "default": "screenshot"
    },
    "interval_sec": {
      "env": "INTERVAL_SEC",
      "default": 3
    },
    "clip_duration_sec": {
      "env": "CLIP_DURATION_SEC",
      "default": 5
    },
    "output_format": {
      "env": "OUTPUT_FORMAT",
      "default": "png"
    }
  }
}
